@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix a-cd: <https://w3id.org/arco/ontology/context-description/> .
@prefix a-ce: <https://w3id.org/arco/ontology/cultural-event/> .
@prefix a-dd: <https://w3id.org/arco/ontology/denotative-description/> .
@prefix a-lite: <https://w3id.org/arco/ontology/arco-lite/> .
@prefix a-loc: <https://w3id.org/arco/ontology/location/> .
@prefix a-arc: <https://w3id.org/archives/ontology/archival-resource/> .
@prefix arco: <https://w3id.org/arco/ontology/arco/> .
@prefix cis: <http://dati.beniculturali.it/cis/> .
@prefix clv: <https://w3id.org/italia/onto/CLV/> .
@prefix core: <https://w3id.org/arco/ontology/core/> .
@prefix cov: <https://w3id.org/italia/onto/COV/> .
@prefix cpv: <https://w3id.org/italia/onto/CPV/> .
@prefix ipac: <https://ipac.cultura.gov.it/onto/ipac/> .
@prefix l0: <https://w3id.org/italia/onto/l0/> .
@prefix lang: <https://w3id.org/italia/onto/Language/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ti: <https://w3id.org/italia/onto/TI/> . 
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <https://w3id.org/arco4archives/shacl/> .

ex:ArchivalItemShape
    a sh:NodeShape ;
    sh:targetClass a-arc:ArchivalItem ;
	sh:property [              
        sh:path core:hasType ;
		sh:nodeKind sh:IRI ; 
		sh:minCount 1 ;
		sh:maxCount 1 ;
		sh:severity sh:Violation ;
		sh:message "La relazione dell'unità documentaria con il suo livello di descrizione è obbligatoria: core:hasType deve essere materializzata"
		] ;
    sh:property [
        sh:path l0:positionInSequence ;
        sh:nodeKind sh:Literal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Il numero di ordinamento dell'unità documentaria è obbligatorio: l0:positionInSequence deve essere materializzato"
        ] ;

    sh:property [
        sh:path a-arc:hasArchivalReferenceCode ;
        sh:class a-arc:ArchivalReferenceCode ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "La relazione dell'unità documentaria con la sua segnatura è obbligatoria: a-arc:hasArchivalReferenceCode deve essere materializzata"
        ] ;
    sh:property [
        sh:path a-cd:hasDesignationInTime ;
        sh:class a-cd:DesignationInTime ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "La relazione dell'unità documentaria con la sua denominazione è obbligatoria: a-cd:hasDesignationInTime deve essere materializzata"
        ] ;
    sh:property [
        sh:path a-cd:hasTitle ;
        sh:class a-cd:Title ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "La relazione dell'unità documentaria con il suo titolo è obbligatoria: a-cd:hasTitle deve essere materializzata"
        ] ;
    sh:property [
        sh:path ti:hasTemporalEntity ;
        sh:class ti:TemporalEntity ;
        ] ;
    sh:property [
        sh:path a-loc:hasTimeIndexedTypedLocation ;
        sh:class a-loc:TimeIndexedTypedLocation ;
        ] ; 
    sh:property [
        sh:path a-lite:hasMaterial ;
        sh:class a-dd:Material ;
        ] ;
    sh:property [
        sh:path a-dd:hasMeasurementCollection ;
        sh:class a-dd:MeasurementCollection ;
        ] ;
    sh:property [
        sh:path a-arc:hasExtent ;
        sh:class a-arc:Extent ;
        ] ;
    sh:property [
        sh:path a-arc:totalExtentInString ;
        sh:nodeKind sh:Literal ;
        ] ;
    sh:property [
        sh:path core:hasIdentifier ;
        sh:class core:Identifier ;
        ] ;
    sh:property [
        sh:path core:description ;
        sh:nodeKind sh:Literal ;
        ] ;
    sh:property [
        sh:path a-arc:hasArrangement ;
        sh:class a-arc:Arrangement ;
        ] ;
    sh:property [
        sh:path lang:hasLanguage ;
        sh:class lang:Language ;
        ] ;
    sh:property [
        sh:path a-dd:hasWritingSystem ;
        sh:class a-dd:WritingSystem ;
        ] ;
    sh:property [
        sh:path a-dd:hasAffixedElement ;
        sh:class a-dd:AffixedElement ;
        ] ;
    sh:property [
        sh:path a-arc:hasConditionOfAccess ;
        sh:class a-arc:ConditionOfAccess ;
        ] ;
    sh:property [
        sh:path a-arc:hasConditionOfUse ;
        sh:class a-arc:ConditionOfUse ; 
        ] ;
    sh:property [
        sh:path a-arc:hasConservationStatus ;
        sh:class a-arc:ConservationStatus ;
        ] ;
    sh:property [
        sh:path a-arc:hasDocumentationRelation ;
        sh:class a-arc:DocumentationRelation ;
        ] ;
    sh:property [
        sh:path a-arc:hasOriginalRelation ;
        sh:class a-arc:CopyOrOriginalRelation ;
        ] ;
    sh:property [
        sh:path a-arc:hasCopyRelation ;
        sh:class a-arc:CopyOrOriginalRelation ;
        ] ;
    sh:property [
        sh:path a-cd:hasResponsibility ;
        sh:or (
            [ sh:class a-cd:Responsibility ]
            [ sh:class a-arc:ArchivalResponsibility ]
        ) ;
        ] ;
    sh:property [
        sh:path a-cd:hasSubject ;
        sh:class a-cd:Subject ;
        ] ;
    sh:property [
        sh:path core:isDescribedBy ;
        sh:class a-arc:FindingAid ;
        ] ;
    sh:property [
        sh:path a-arc:hasEvent ;
        sh:class a-arc:Event ;
        ] ;
    sh:property [
        sh:path a-arc:hasArchivalProject ;
        sh:class a-arc:ArchivalProject ;
        ] ;
    sh:property [
        sh:path l0:hasTopic ;
        sh:class l0:Topic ;
        ] ;
    sh:property [
        sh:path a-arc:hasReference ;
        sh:or (
            [ sh:class a-cd:Publication ]
            [ sh:class a-arc:WebReference ]
        ) ;
        ] ;
    sh:property [
        sh:path a-arc:hasSource ;
        sh:or (
            [ sh:class a-arc:ArchivalResource ]
            [ sh:class a-arc:ArchivalResourceSet ]
            [ sh:class a-arc:ArchivalUnit ]
            [ sh:class a-arc:ArchivalItem ]
            [ sh:class a-arc:LegalResource ]
        ) ;
        ] .