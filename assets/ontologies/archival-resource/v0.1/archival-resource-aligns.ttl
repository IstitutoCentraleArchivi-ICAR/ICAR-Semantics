###  https://w3id.org/arco/archives/ontology/archival-resource/hasParentArchivalSet
a-arc:hasParentArchivalSet rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf rico:isOrWasIncludedIn ;
                           rdfs:isDefinedBy <https://w3id.org/arco/archives/ontology/archival-resource> .


###  https://w3id.org/arco/ontology/arco-lite/hasAuthor
a-lite:hasAuthor rdf:type owl:ObjectProperty ;
                 owl:equivalentProperty rico:hasAuthor ;
                 rdfs:isDefinedBy <https://w3id.org/arco/ontology/arco-lite> .


###  https://w3id.org/arco/ontology/arco-lite/hasHolder
a-lite:hasHolder rdf:type owl:ObjectProperty ;
